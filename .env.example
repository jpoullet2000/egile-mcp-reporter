# Output Configuration
DEFAULT_FORMAT=pdf
OUTPUT_DIR=./reports

# PDF Settings
PDF_PAGE_SIZE=A4  # A4, Letter, Legal
PDF_MARGINS=20mm
PDF_ORIENTATION=portrait  # portrait, landscape

# PowerPoint Settings
PPTX_THEME=default
PPTX_SLIDE_WIDTH=10
PPTX_SLIDE_HEIGHT=7.5

# Chart Settings
CHART_THEME=plotly_white
CHART_DPI=300
CHART_WIDTH=800
CHART_HEIGHT=600

# HTML Settings
HTML_THEME=default  # default, dark, light
HTML_RESPONSIVE=true

# Logging
LOG_LEVEL=INFO
